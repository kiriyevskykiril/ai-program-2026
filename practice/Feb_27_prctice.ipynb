    }
   ],
   "source": [
    "x = np.linspace(-6, 6 , 101)\n",
    "plt.plot(x, expit(x), marker='o', markersize=2)\n",
    "plt.plot(x, 2 * expit(x) - 1)\n",
    "plt.axvline(x=0, c= 'k')\n",
    "plt.axhline(y=0, c= 'k')\n",
    "plt.show()"
   ]
